# LLM_PROVIDER selects the chatbot backend: fake, gemini, or anthropic.
# fake needs no API key and is the default for the live class demo.
# Free tier prompts on gemini/anthropic may be used by the provider for
# training, so do not paste real customer data into this lab.
LLM_PROVIDER=fake
GEMINI_API_KEY=
GEMINI_MODEL=
ANTHROPIC_API_KEY=
